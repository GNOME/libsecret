#: libsecret/secret-item.c:1130
#, c-format
msgid "Received invalid secret from the secret storage"
msgstr "ได้รับข้อมูลลับที่ไม่ถูกต้องจากหน่วยเก็บข้อมูลลับ"

#: libsecret/secret-methods.c:1058
msgid "Default keyring"
msgstr "พวงกุญแจเริ่มต้น"

#: libsecret/secret-session.c:260 libsecret/secret-session.c:296
msgid "Couldn’t communicate with the secret storage"
msgstr "ไม่สามารถสื่อสารกับหน่วยเก็บข้อมูลลับได้"

#: tool/secret-tool.c:42
msgid "the label for the new stored item"
msgstr "ฉลากสำหรับรายการใหม่ที่เก็บ"

#: tool/secret-tool.c:44
msgid "the collection in which to place the stored item"
msgstr "ชุดรวมที่จะวางรายการที่เก็บ"

#: tool/secret-tool.c:46 tool/secret-tool.c:53 tool/secret-tool.c:477
msgid "attribute value pairs of item to lookup"
msgstr "คู่ของค่าแอตทริบิวต์ของรายการที่จะค้นหา"

#: tool/secret-tool.c:60
msgid "attribute value pairs which match items to clear"
msgstr "คู่ของค่าแอตทริบิวต์ซึ่งตรงกับรายการที่จะล้าง"

#: tool/secret-tool.c:67
msgid "collection in which to lock"
msgstr "ชุดรวมที่จะล็อก"

#: tool/secret-tool.c:473
msgid "return all results, instead of just first one"
msgstr "คืนค่าผลลัพธ์ทั้งหมด แทนที่จะเป็นแค่อันเดียว"

#: tool/secret-tool.c:475
msgid "unlock item results if necessary"
msgstr "ปลดล็อกผลลัพธ์รายการถ้าจำเป็น"
